# Module / project files (Android Studio / IntelliJ)
*.iml

# Gradle cache and locally generated files
.gradle/

# Local SDK paths and machine-specific configuration
local.properties
/local.properties

# Android Studio / IntelliJ IDEA internal configuration files
.idea/
!.idea/gradle.xml
!.idea/vcs.xml
!.idea/misc.xml
!.idea/compiler.xml
!.idea/runConfigurations/

# macOS system file generated by Finder
.DS_Store

# Build outputs (APK, AAB, intermediates)
/build/

# Screen captures generated by Android Studio
/captures/

# Native builds (CMake / NDK) generated directories
.externalNativeBuild/
.cxx/

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*
